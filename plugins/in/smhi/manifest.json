{
  "id": "com.heimwatt.smhi",
  "type": "in",
  "name": "SMHI Weather",
  "version": "1.0.0",
  "binary": "smhi",
  "provides": {
    "known": [
      "ATMOSPHERE_TEMPERATURE",
      "ATMOSPHERE_HUMIDITY",
      "ATMOSPHERE_CLOUD_COVER",
      "ATMOSPHERE_PRESSURE"
    ],
    "raw": [
      "smhi.wind_direction",
      "smhi.precipitation_category"
    ]
  },
  "schedule": {
    "interval_seconds": 3600,
    "on_startup": true
  }
}
